<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs Include Filter
    ═══════════════════════
    Only the bug patterns listed here are enforced. All other SpotBugs rules
    are ignored. This restricts analysis strictly to serialization correctness.
-->
<FindBugsFilter>

    <!-- Field in a Serializable class is not Serializable -->
    <Match>
        <Bug pattern="SE_BAD_FIELD" />
    </Match>

    <!-- Serializable class has a non-Serializable parent with no no-arg constructor -->
    <Match>
        <Bug pattern="SE_NO_SUITABLE_CONSTRUCTOR" />
    </Match>

    <!-- Serializable class missing serialVersionUID -->
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID" />
    </Match>

    <!-- Non-serializable value stored into a Serializable field -->
    <Match>
        <Bug pattern="SE_BAD_FIELD_STORE" />
    </Match>

</FindBugsFilter>
